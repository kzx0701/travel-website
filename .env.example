# Supabase 项目凭证
# 请前往 https://supabase.com 控制台创建项目后，在 Project Settings > API 中获取以下值
# 复制本文件为 .env 并填入你自己的凭证，不要提交 .env 到版本库

# 项目 URL，形如 https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# 匿名公钥（anon public key），可安全暴露到前端
VITE_SUPABASE_ANON_KEY=your-anon-public-key
